# inbox/input.md and inbox/jobs.md are tracked as guidance-only TEMPLATES so the
# structure ships with the repo. They contain no résumé/job data. To keep your
# own edits from ever being committed, run once:
#   git update-index --skip-worktree inbox/input.md inbox/jobs.md
# Generated data stays private by default:
data/jobs/details/*.md
data/results/*.md
data/manual-search-links.md
output/ranking.html
output/ranking.md

# Keep the folders tracked
!data/jobs/details/.gitkeep
!data/results/.gitkeep

__pycache__/
*.pyc
.venv/
.DS_Store

# Vendored LinkedIn CLI: commit the source, not installed deps
tools/linkedin-cli/node_modules/
